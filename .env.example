# Christian Bot — environment template.
# Copy to `.env` and fill in values:  cp .env.example .env
# All [required] vars MUST be set before `docker compose up`.

# ===== DeepSeek (parser cross-check, 3 × V4 Flash) =====
# [required] API key for DeepSeek — drives CrossCheckParser (2/3 majority vote).
DEEPSEEK_API_KEY=
# [optional] Override base URL (default: https://api.deepseek.com).
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===== Telegram (alerts + /stop command + drill confirm) =====
# [required] Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=
# [required] Chat id where alerts are pushed and /stop is accepted.
# Get it: send a message to the bot, then visit
#   https://api.telegram.org/bot<TOKEN>/getUpdates  →  look for chat.id
TELEGRAM_CHAT_ID=

# ===== Webull (paper trading) =====
# [required] Paper-trading account id. Real account ids are never used in MVP.
WEBULL_UAT_ACCOUNT_ID=

# ===== Claude CLI (InstructionParser fallback / manual parse) =====
# [optional] Per-run spend cap passed to the Claude CLI.
# CLAUDE_MAX_BUDGET_USD=5.00

# ===== Dashboard kill switch (POST /api/kill-switch) =====
# [required] Secret compared against X-Kill-Switch-Secret header.
# Generate with:  openssl rand -hex 32
DASHBOARD_KILL_SWITCH_SECRET=

# ===== Substack (mcp-substack poll) =====
# [optional] Comma-separated publication ids to poll. Blank = use defaults.
# SUBSTACK_PUBLICATION_IDS=

# ===== Substack session expiry detection (Task 5.9) =====
# The daemon's circuit breaker (Task 2.5) already covers consecutive failures.
# Task 5.9 adds a SECOND trigger: N consecutive zero-post polls implies the
# Substack cookie (storage-state.json) has expired silently. Default N=6.
# On trigger: Telegram alert is pushed (see src/ops/daemon.py zero-post path).
# [optional]
# SUBSTACK_ZERO_POST_ALERT_THRESHOLD=6
